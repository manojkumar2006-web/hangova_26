generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Group {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  code      String    @unique
  isPublic  Boolean   @default(false)
  createdAt DateTime  @default(now())
  members   User[]
  content   Content[]
}

model User {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  username      String         @unique
  email         String         @unique
  password      String
  avatarUrl     String?
  isAdmin       Boolean        @default(false)
  group         Group?         @relation(fields: [groupId], references: [id])
  groupId       String?        @db.ObjectId
  createdAt     DateTime       @default(now())
  content       Content[]
  comments      Comment[]
  reactions     Reaction[]
  reminders     Reminder[]
  playlists     Playlist[]
  messages      Message[]
  watchProgress WatchProgress[]
  pushSubs      PushSubscription[]
}

model Content {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  type           ContentType
  source         ContentSource
  fileUrl        String?
  youtubeVideoId String?
  title          String
  description    String?
  thumbnailUrl   String?
  genre          String?
  downloadable   Boolean        @default(false)
  isFeatured     Boolean        @default(false)
  group          Group          @relation(fields: [groupId], references: [id])
  groupId        String         @db.ObjectId
  uploadedBy     User?          @relation(fields: [uploadedById], references: [id])
  uploadedById   String?        @db.ObjectId
  createdAt      DateTime       @default(now())
  comments       Comment[]
  reactions      Reaction[]
  scheduledDrop  ScheduledDrop?
  watchProgress  WatchProgress[]
}

enum ContentType {
  movie
  reel
  song
}

enum ContentSource {
  upload
  youtube
}

model WatchProgress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.ObjectId
  content     Content  @relation(fields: [contentId], references: [id])
  contentId   String   @db.ObjectId
  progressSec Int      @default(0)
  durationSec Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([userId, contentId])
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   Content  @relation(fields: [contentId], references: [id])
  contentId String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  text      String
  createdAt DateTime @default(now())
}

model Reaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   Content  @relation(fields: [contentId], references: [id])
  contentId String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  type      String   @default("like")

  @@unique([userId, contentId, type])
}

model ScheduledDrop {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  content   Content    @relation(fields: [contentId], references: [id])
  contentId String     @unique @db.ObjectId
  dropAt    DateTime
  reminders Reminder[]
}

model Reminder {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  user            User          @relation(fields: [userId], references: [id])
  userId          String        @db.ObjectId
  scheduledDrop   ScheduledDrop @relation(fields: [scheduledDropId], references: [id])
  scheduledDropId String        @db.ObjectId
  notified        Boolean       @default(false)

  @@unique([userId, scheduledDropId])
}

model Playlist {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  userId     String   @db.ObjectId
  name       String
  contentIds String[] @db.ObjectId
  coverUrl   String?
  createdAt  DateTime @default(now())
}

model Conversation {
  id        String               @id @default(auto()) @map("_id") @db.ObjectId
  isGroup   Boolean              @default(false)
  name      String?
  groupId   String?              @db.ObjectId
  members   ConversationMember[]
  messages  Message[]
  createdAt DateTime             @default(now())
}

model ConversationMember {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String       @db.ObjectId
  userId         String       @db.ObjectId

  @@unique([conversationId, userId])
}

model Message {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  conversationId  String       @db.ObjectId
  sender          User         @relation(fields: [senderId], references: [id])
  senderId        String       @db.ObjectId
  text            String?
  sharedContentId String?      @db.ObjectId
  createdAt       DateTime     @default(now())
}

model PushSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model YoutubeCache {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId      String   @unique
  title        String
  description  String?
  thumbnailUrl String
  channelName  String
  duration     String?
  cachedAt     DateTime @default(now())
}

model OtpToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
